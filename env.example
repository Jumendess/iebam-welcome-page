# ═══════════════════════════════════════════════════════════════
# VARIÁVEIS DE AMBIENTE — IEBAM SITE
# Copie este arquivo para .env e preencha com os valores reais
# NUNCA envie o arquivo .env para o GitHub!
# ═══════════════════════════════════════════════════════════════

# ── YouTube API ──────────────────────────────────────────────────
# Como obter a chave: console.cloud.google.com
#   → Selecione o projeto → APIs e serviços → Credenciais
#   → Criar credenciais → Chave de API
VITE_YOUTUBE_API_KEY=SUA_CHAVE_AQUI

# Como obter o ID do canal: studio.youtube.com
#   → Ícone do perfil → Configurações → Canal → Informações básicas
VITE_YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxx

# ── Redes Sociais ────────────────────────────────────────────────
VITE_YOUTUBE_URL=https://www.youtube.com/@SEU_CANAL
VITE_INSTAGRAM_URL=https://instagram.com/SEU_PERFIL
VITE_FACEBOOK_URL=https://facebook.com/SUA_PAGINA

# ── Contato ──────────────────────────────────────────────────────
# Só números: 55 (Brasil) + DDD + número, sem espaços ou traços
VITE_WHATSAPP_NUMERO=5511999999999
VITE_EMAIL=contato@suaigreja.org.br

# ── Google Maps ──────────────────────────────────────────────────
# Como obter: google.com/maps → sua igreja → Compartilhar
#   → Incorporar mapa → copie o src do iframe
VITE_MAPS_EMBED=https://www.google.com/maps/embed?pb=SEU_EMBED_AQUI
